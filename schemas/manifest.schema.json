{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcapsule.dev/schemas/manifest.schema.json",
  "title": "Agent Capsule Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "agent_name",
    "agent_version",
    "language",
    "runtime_version",
    "sdk_version",
    "container_digest",
    "dependency_hashes",
    "prompt_template_hashes",
    "tool_definitions",
    "model_configuration",
    "policy_hash",
    "policy_version",
    "network_destinations",
    "required_secrets",
    "usage_meters",
    "signature"
  ],
  "properties": {
    "manifest_version": {
      "type": "integer",
      "minimum": 1
    },
    "agent_name": {
      "type": "string"
    },
    "agent_version": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "enum": [
        "python",
        "typescript",
        "java",
        "go",
        "rust"
      ]
    },
    "runtime_version": {
      "type": "string"
    },
    "sdk_version": {
      "type": "string"
    },
    "container_digest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "dependency_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      }
    },
    "prompt_template_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      }
    },
    "tool_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version",
          "schema_hash"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "schema_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "model_configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "configuration_hash"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "configuration_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "policy_version": {
      "type": "integer",
      "minimum": 1
    },
    "network_destinations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "domain",
          "risk"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "domain": {
            "type": [
              "string",
              "null"
            ]
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          }
        }
      }
    },
    "required_secrets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "usage_meters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "unit"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string"
        },
        "key_id": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    }
  }
}
