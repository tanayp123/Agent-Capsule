{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcapsule.dev/schemas/trace.schema.json",
  "title": "Agent Capsule Trace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_schema_version",
    "trace_id",
    "run_id",
    "agent",
    "mode",
    "language",
    "runtime_version",
    "sdk_version",
    "created_at",
    "spans",
    "destinations"
  ],
  "properties": {
    "trace_schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trc_[a-zA-Z0-9_-]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-zA-Z0-9_-]+$"
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "observe",
        "guard",
        "confidential"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "python",
        "typescript",
        "java",
        "go",
        "rust"
      ]
    },
    "runtime_version": {
      "type": "string"
    },
    "sdk_version": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "spans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "span_id",
          "parent_span_id",
          "component_type",
          "component_name",
          "start_time",
          "end_time",
          "status",
          "payload_size_bytes",
          "token_count",
          "content_hash",
          "data_classes",
          "destination_id",
          "policy_decision",
          "error_summary",
          "redaction_markers"
        ],
        "properties": {
          "span_id": {
            "type": "string",
            "pattern": "^spn_[a-zA-Z0-9_-]+$"
          },
          "parent_span_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "component_type": {
            "type": "string",
            "enum": [
              "workflow",
              "model_call",
              "tool_call",
              "retrieval_call",
              "database_call",
              "network_egress",
              "approval",
              "policy_decision"
            ]
          },
          "component_name": {
            "type": "string"
          },
          "start_time": {
            "type": "string"
          },
          "end_time": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "error",
              "blocked",
              "redacted",
              "approval_required"
            ]
          },
          "payload_size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "token_count": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "content_hash": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "data_classes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "destination_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "policy_decision": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action",
              "reason",
              "policy_version",
              "fields"
            ],
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "allow",
                  "allow_fields",
                  "redact",
                  "require_approval",
                  "block",
                  "warn",
                  "not_evaluated"
                ]
              },
              "reason": {
                "type": "string"
              },
              "policy_version": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "error_summary": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "required": [
              "type",
              "message",
              "stack_hash"
            ],
            "properties": {
              "type": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "stack_hash": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              }
            }
          },
          "redaction_markers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "destinations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "domain",
          "provider",
          "environment",
          "risk",
          "declared_in_policy",
          "allowed_data_classes",
          "observed_data_classes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "domain": {
            "type": [
              "string",
              "null"
            ]
          },
          "provider": {
            "type": "string"
          },
          "environment": {
            "type": "string"
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "declared_in_policy": {
            "type": "boolean"
          },
          "allowed_data_classes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "observed_data_classes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
